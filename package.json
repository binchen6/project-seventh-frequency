{
  "name": "seventh-frequency",
  "version": "1.0.0",
  "private": true,
  "description": "A 1930s Shanghai sci-fi mystery visual novel built with HTML5 Canvas and vanilla JavaScript.",
  "type": "commonjs",
  "scripts": {
    "prepare:static": "node scripts/prepare-static-pages.cjs",
    "optimize:engine": "node scripts/optimize-engine-briefs.cjs",
    "validate": "npm run prepare:static && node --check web/js/engine.js && node --check scripts/smoke-test.cjs && node scripts/validate-project.cjs",
    "build:pages": "npm run validate && node scripts/build-pages.cjs",
    "serve": "node scripts/serve-web.cjs web",
    "serve:dist": "node scripts/serve-web.cjs dist",
    "smoke": "node scripts/smoke-test.cjs",
    "smoke:dist": "node scripts/smoke-test.cjs dist"
  },
  "keywords": [
    "visual-novel",
    "html5",
    "canvas",
    "interactive-fiction",
    "github-pages"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "playwright": "^1.59.1"
  }
}
